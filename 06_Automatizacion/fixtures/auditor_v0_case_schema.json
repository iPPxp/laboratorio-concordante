{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AUDITOR-V0-CASE-SCHEMA-001",
  "title": "Auditor v0 external case file",
  "type": "object",
  "required": [
    "cases"
  ],
  "additionalProperties": false,
  "properties": {
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "automaton",
            "claim",
            "authority",
            "level_change",
            "term"
          ]
        },
        "claim_status": {
          "type": "string"
        },
        "declaration": {
          "type": "object",
          "properties": {
            "deterministic": {
              "type": "boolean"
            },
            "complete": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "automaton": {
          "$ref": "#/$defs/automaton"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "justification": {
          "type": "string"
        },
        "required_dependency": {
          "type": "string",
          "minLength": 1
        },
        "dependency_materialized": {
          "type": "boolean"
        },
        "forbidden_promotion": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "registered_decision": {
          "type": "boolean"
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "term": {
          "type": "string",
          "minLength": 1
        },
        "term_status": {
          "type": "string"
        },
        "transformation": {
          "type": "object",
          "properties": {
            "executed": {
              "type": "boolean"
            },
            "decision_emitida": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "automaton"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "automaton"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "claim"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "claim",
              "required_dependency",
              "dependency_materialized"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "authority"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "claim",
              "source",
              "registered_decision"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "level_change"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "surface",
              "action",
              "registered_decision"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "term"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "text",
              "term",
              "term_status"
            ]
          }
        }
      ]
    },
    "automaton": {
      "type": "object",
      "required": [
        "states",
        "alphabet",
        "initial",
        "finals",
        "transitions"
      ],
      "additionalProperties": false,
      "properties": {
        "states": {
          "$ref": "#/$defs/string_list"
        },
        "alphabet": {
          "$ref": "#/$defs/string_list"
        },
        "initial": {
          "type": "string",
          "minLength": 1
        },
        "finals": {
          "$ref": "#/$defs/string_list"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        }
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "transition": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    }
  }
}
