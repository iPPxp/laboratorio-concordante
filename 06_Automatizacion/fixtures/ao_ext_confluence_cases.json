  "description": "Casos sinteticos no regulados para pruebas externas locales de Confluencia.",
  "cases": [
    {
      "case_id": "EXT-CONF-001A",
      "test_id": "EXT-CONF-001",
      "domain": "tabla_datos_sintetica",
      "route_a": "normalizacion_csv",
      "route_b": "normalizacion_json",
      "expected": "confluencia_local",
      "schema": {
        "fields": [
          {"name": "id", "type": "int", "required": true},
          {"name": "status", "type": "enum", "allowed": ["active", "blocked"], "required": true},
          {"name": "score", "type": "int", "required": false}
        ]
      },
      "route_a_input": {
        "format": "csv",
        "content": "id,status,score\n1,active,10\n2,blocked,0\n"
      },
      "route_b_input": {
        "format": "json_rows",
        "rows": [
          {"id": 1, "status": "active", "score": 10},
          {"id": 2, "status": "blocked", "score": 0}
        ]
      }
    },
    {
      "case_id": "EXT-CONF-001B",
